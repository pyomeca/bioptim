<?xml version="1.0"?>
<robot name="Pendulum">

  <!-- World link -->
  <link name="world"/>

  <!-- Intermediate link for Y translation -->
  <link name="Seg1_translation_link"/>

  <!-- Prismatic joint: translation along y -->
  <joint name="Seg1_translation_y" type="prismatic">
    <parent link="world"/>
    <child link="Seg1_translation_link"/>

    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>

    <limit lower="-1" upper="5" effort="1000" velocity="100"/>
  </joint>

  <!-- Main segment link -->
  <link name="Seg1">
    <inertial>
      <!-- Center of mass -->
      <origin xyz="-0.0005 0.0688 -0.9542" rpy="0 0 0"/>

      <mass value="1"/>

      <inertia
        ixx="0.0391"
        ixy="0.0000"
        ixz="0.0000"
        iyy="0.0335"
        iyz="-0.0032"
        izz="0.0090"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="mesh/pendulum.STL"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="mesh/pendulum.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- Revolute joint: rotation about x -->
  <joint name="Seg1_rotation_x" type="revolute">
    <parent link="Seg1_translation_link"/>
    <child link="Seg1"/>

    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>

    <limit lower="-6.28318530718"
           upper="6.28318530718"
           effort="1000"
           velocity="100"/>
  </joint>

  <!-- Marker 1 -->
  <link name="marker_1"/>

  <joint name="marker_1_fixed" type="fixed">
    <parent link="Seg1"/>
    <child link="marker_1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Marker 2 -->
  <link name="marker_2"/>

  <joint name="marker_2_fixed" type="fixed">
    <parent link="Seg1"/>
    <child link="marker_2"/>
    <origin xyz="-0.0005 0.0688 -0.9542" rpy="0 0 0"/>
  </joint>

</robot>